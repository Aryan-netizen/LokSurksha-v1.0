DATABASE_URL=sqlite:///your_database.db
SECRET_KEY=your_secret_key
UPLOAD_FOLDER=uploads
WEBSOCKET_URL=ws://localhost:5000/socket
DEBUG=True
REQUIRE_REPORT_OTP=true
OTP_PROVIDER=twilio
OTP_DEV_MODE=false
OTP_EXPIRY_SECONDS=300
OTP_VERIFIED_TOKEN_EXPIRY_SECONDS=900
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
HYPERVERGE_FIR_VERIFY_URL=https://your-hyperverge-endpoint
HYPERVERGE_APP_ID=your_hyperverge_app_id
HYPERVERGE_APP_KEY=your_hyperverge_app_key
HYPERVERGE_BEARER_TOKEN=
HYPERVERGE_HTTP_METHOD=POST
HYPERVERGE_TIMEOUT_SECONDS=20
